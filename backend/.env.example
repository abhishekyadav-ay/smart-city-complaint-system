# Backend environment example for production deployment.
# Copy this file to backend/.env for local development only.
# Never commit real secrets to source control.

# Server settings
PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
# Example: mongodb+srv://<user>:<password>@cluster0.mongodb.net/smart-city?retryWrites=true&w=majority
MONGO_URI=your-mongodb-atlas-connection-string

# JWT secret used for signing and verifying admin tokens
JWT_SECRET=your-very-long-random-jwt-secret

# Admin registration bootstrap secret
# Used by the first admin seed flow and admin creation route.
ADMIN_SECRET_KEY=your-admin-registration-secret

# Frontend URL for CORS validation
FRONTEND_URL=https://your-netlify-site.netlify.app

# Optional additional allowed origins (comma-separated)
# Example: https://preview-123.netlify.app,https://admin.example.com
ALLOWED_ORIGINS=

# Email settings for notifications (optional)
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-app-password
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
ADMIN_EMAIL=admin-notification-email@example.com

# Optional OpenAI key for improved issue classification.
# Keep as placeholder to use keyword fallback instead.
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional local admin seeding defaults. Replace before use in any shared environment.
DEFAULT_ADMIN_USER=superadmin
DEFAULT_ADMIN_PASS=SuperAdmin@2024
DEFAULT_ADMIN_NAME=Super Administrator

# Optional: Use S3 for storing uploaded images. Set to 'true' to enable.
USE_S3=false

# When USE_S3=true, configure these AWS credentials and bucket
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket-name

